# PostgreSQL
POSTGRES_DB=backoffice_service_portal
POSTGRES_USER=backoffice_app
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# JWT
JWT_KEY=CHANGE_ME_JWT_SIGNING_KEY

# HTTPS certificate mounted into the backend container
HTTPS_CERT_HOST_PATH=/https/backoffice-service-portal.pfx
HTTPS_CERT_PATH=/https/backoffice-service-portal.pfx
HTTPS_CERT_PASSWORD=CHANGE_ME_CERTIFICATE_PASSWORD

# Bootstrap admin account
BootstrapAdmin__Username=admin
BootstrapAdmin__Password=CHANGE_ME_ADMIN_PASSWORD
BootstrapAdmin__Email=admin@example.com
BootstrapAdmin__FullName=Backoffice Admin

# Optional container image overrides.
# Leave commented to use docker-compose.yml defaults.
# DEPLOY_IMAGE_REPOSITORY=ghcr.io/your-owner/your-image
# DEPLOY_IMAGE_TAG=latest
